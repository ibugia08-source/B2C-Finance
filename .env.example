# ===== Banco (Supabase — projeto PRÓPRIO do B2C Finance) =====
# Copie os valores reais de: Vercel → projeto B2C → Settings → Environment Variables
# POSTGRES_PRISMA_URL      = conexão COM POOL (app em runtime)
# POSTGRES_URL_NON_POOLING = conexão DIRETA (migrations)
POSTGRES_PRISMA_URL="postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ===== Sessão =====
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="troque-por-um-segredo-de-32+chars"

# ===== Supabase (client + storage de arquivos) =====
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon-key"
SUPABASE_SERVICE_ROLE_KEY="service-role-key (obrigatória p/ upload de contratos em produção)"
B2C_STORAGE_BUCKET="b2c-finance-files"
